{% comment %}
  APEX Performance — Main Banner
  Full-viewport dark hero with bold graphic typography
{% endcomment %}

<section style="position:relative;min-height:100svh;background:#0A0A0A;overflow:hidden;display:flex;align-items:flex-end;">
  
  {% comment %} Outlined text "TRAIN" {% endcomment %}
  <div style="position:absolute;bottom:52%;left:-0.01em;font-family:'Geist','Arial Black',sans-serif;font-size:clamp(80px,16vw,220px);font-weight:900;color:transparent;-webkit-text-stroke:2px rgba(255,255,255,0.85);line-height:0.9;pointer-events:none;z-index:2;">
    TRAIN
  </div>

  {% comment %} Filled text "HARDER" {% endcomment %}
  <div style="position:absolute;bottom:28%;left:-0.01em;font-family:'Geist','Arial Black',sans-serif;font-size:clamp(80px,16vw,220px);font-weight:900;color:#FFFFFF;line-height:0.9;pointer-events:none;z-index:2;">
    HARDER
  </div>

  {% comment %} Red diagonal bar {% endcomment %}
  <div style="position:absolute;width:5px;height:35vh;background:#FF4500;right:32%;top:12%;transform:rotate(-14deg);z-index:3;"></div>

  {% comment %} Athlete/product image {% endcomment %}
  {% if section.settings.image %}
    <img 
      src="{{ section.settings.image | image_url: width: 1200 }}"
      srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
              {{ section.settings.image | image_url: width: 900 }} 900w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 1600 }} 1600w"
      sizes="44vw"
      alt="{{ section.settings.image.alt | escape }}"
      loading="eager"
      style="position:absolute;right:0;top:0;width:44%;height:100%;object-fit:cover;object-position:center;mix-blend-mode:luminosity;opacity:0.75;z-index:1;"
    >
  {% endif %}

  {% comment %} Red vignette overlay on image {% endcomment %}
  <div style="position:absolute;right:0;top:0;width:44%;height:100%;background:linear-gradient(to left, rgba(255,69,0,0.18) 0%, transparent 100%);z-index:2;"></div>

  {% comment %} CTA block {% endcomment %}
  <div style="position:absolute;bottom:60px;left:40px;z-index:10;">
    <p style="font-size:11px;letter-spacing:0.2em;color:rgba(255,255,255,0.5);text-transform:uppercase;margin:0 0 16px;font-family:'Geist',sans-serif;">Built for Performance</p>
    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" style="background:#FF4500;color:#fff;text-decoration:none;padding:16px 40px;border-radius:100px;font-size:13px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;font-family:'Geist',sans-serif;transition:transform 0.2s ease,box-shadow 0.2s ease;display:inline-block;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(255,69,0,0.4)';" onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none';">
        {{ section.settings.cta_text | default: 'Shop Now' }} →
      </a>
      <a href="{{ section.settings.secondary_link | default: '/pages/our-story' }}" style="border:1px solid rgba(255,255,255,0.3);color:#fff;text-decoration:none;padding:15px 32px;border-radius:100px;font-size:13px;font-family:'Geist',sans-serif;background:transparent;transition:background 0.2s ease,border-color 0.2s ease;display:inline-block;" onmouseover="this.style.background='rgba(255,255,255,0.05)';this.style.borderColor='rgba(255,255,255,0.5)';" onmouseout="this.style.background='transparent';this.style.borderColor='rgba(255,255,255,0.3)';">
        {{ section.settings.secondary_text | default: 'Our Story' }}
      </a>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Main Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Athlete / product image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TRAIN HARDER"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link",
      "default": "/pages/our-story"
    }
  ],
  "presets": [
    {
      "name": "Main Banner"
    }
  ]
}
{% endschema %}