{% comment %}
  APEX PERFORMANCE — KINETIC FULL-VIEWPORT HERO
  Diagonal brand name reveal, aggressive red accents, athletic energy
{% endcomment %}

<section class="forge-apex-hero" data-section-id="{{ section.id }}">
  <div class="apex-hero__container">
    
    {%- comment -%} DIAGONAL BRAND NAME — OUTLINE VERSION {%- endcomment -%}
    <div class="apex-ghost" aria-hidden="true">
      APEX
    </div>

    {%- comment -%} DIAGONAL BRAND NAME — FILLED VERSION (reveals via clip-path) {%- endcomment -%}
    <div class="apex-fill" aria-hidden="true">
      APEX
    </div>

    {%- comment -%} DIAGONAL RED ACCENT LINES {%- endcomment -%}
    <div class="apex-line apex-line--1" aria-hidden="true"></div>
    <div class="apex-line apex-line--2" aria-hidden="true"></div>
    <div class="apex-line apex-line--3" aria-hidden="true"></div>

    {%- comment -%} HERO IMAGE — RIGHT 45% WITH DIAGONAL CLIP {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      <div class="apex-hero__media">
        {{
          section.settings.image
          | image_url: width: 1920
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            width: section.settings.image.width,
            height: section.settings.image.height,
            alt: section.settings.image.alt | escape,
            class: 'apex-hero__image',
            data-forge-parallax: '0.3'
        }}
      </div>
    {%- else -%}
      <div class="apex-hero__media apex-hero__media--placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'apex-hero__placeholder' }}
      </div>
    {%- endif -%}

    {%- comment -%} HEADLINE BLOCK — BOTTOM LEFT {%- endcomment -%}
    <div class="apex-hero__content">
      {%- if section.settings.subheading != blank -%}
        <p class="apex-hero__eyebrow">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="apex-hero__heading" data-forge-split="chars" data-forge-split-anim="wave">
          {{ section.settings.heading }}
        </h1>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a 
          href="{{ section.settings.button_link }}" 
          class="apex-hero__cta"
          data-forge-magnet="0.5"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  .forge-apex-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    background: #0A0A0A;
    overflow: hidden;
  }

  .apex-hero__container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* ══════════════════════════════════════
     DIAGONAL BRAND NAME — OUTLINE
     ══════════════════════════════════════ */
  .apex-ghost {
    position: absolute;
    top: -5%;
    left: -3%;
    z-index: 1;
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 900;
    font-size: clamp(12rem, 20vw, 22rem);
    line-height: 0.85;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.08);
    color: transparent;
    transform: rotate(-5deg);
    pointer-events: none;
    user-select: none;
    text-transform: uppercase;
  }

  /* ══════════════════════════════════════
     DIAGONAL BRAND NAME — FILLED (REVEALS)
     ══════════════════════════════════════ */
  .apex-fill {
    position: absolute;
    top: -5%;
    left: -3%;
    z-index: 2;
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 900;
    font-size: clamp(12rem, 20vw, 22rem);
    line-height: 0.85;
    color: white;
    transform: rotate(-5deg);
    pointer-events: none;
    user-select: none;
    text-transform: uppercase;
    clip-path: inset(0 100% 0 0);
    animation: apex-reveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  @keyframes apex-reveal {
    to {
      clip-path: inset(0 0% 0 0);
    }
  }

  /* ══════════════════════════════════════
     DIAGONAL RED ACCENT LINES
     ══════════════════════════════════════ */
  .apex-line {
    position: absolute;
    background: #FF4500;
    height: 3px;
    transform: rotate(-5deg);
    opacity: 0;
    animation: apex-line-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .apex-line--1 {
    width: 120px;
    top: 30%;
    left: 2%;
    animation-delay: 0.3s;
  }

  .apex-line--2 {
    width: 80px;
    top: 45%;
    left: 5%;
    animation-delay: 0.5s;
  }

  .apex-line--3 {
    width: 200px;
    top: 60%;
    left: 0%;
    animation-delay: 0.7s;
  }

  @keyframes apex-line-in {
    to {
      opacity: 1;
    }
  }

  /* ══════════════════════════════════════
     HERO IMAGE — RIGHT 45% DIAGONAL CLIP
     ══════════════════════════════════════ */
  .apex-hero__media {
    position: absolute;
    right: 0;
    top: 0;
    width: 45%;
    height: 100%;
    z-index: 3;
    clip-path: polygon(8% 0%, 100% 0%, 100% 100%, 0% 100%);
  }

  .apex-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.15) contrast(1.1);
  }

  .apex-hero__media--placeholder {
    background: #1A1A1A;
  }

  .apex-hero__placeholder {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  /* ══════════════════════════════════════
     HEADLINE BLOCK — BOTTOM LEFT
     ══════════════════════════════════════ */
  .apex-hero__content {
    position: absolute;
    bottom: 60px;
    left: 60px;
    z-index: 5;
    max-width: 600px;
  }

  .apex-hero__eyebrow {
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 500;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 0.6rem;
  }

  .apex-hero__heading {
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(3rem, 5vw, 5.5rem);
    letter-spacing: -0.01em;
    color: white;
    margin: 0.6rem 0 1.6rem;
    line-height: 1;
    text-wrap: balance;
  }

  .apex-hero__cta {
    display: inline-block;
    padding: 14px 32px;
    background: #FF4500;
    color: white;
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
    border-radius: 100px;
    transition: all 0.2s ease;
  }

  .apex-hero__cta:hover {
    box-shadow: 0 0 30px rgba(255, 69, 0, 0.4);
    transform: translateY(-2px);
  }

  /* ══════════════════════════════════════
     RESPONSIVE
     ══════════════════════════════════════ */
  @media screen and (max-width: 989px) {
    .apex-ghost,
    .apex-fill {
      font-size: clamp(8rem, 18vw, 12rem);
      top: -3%;
      left: -5%;
    }

    .apex-hero__media {
      width: 55%;
      clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
    }

    .apex-hero__content {
      bottom: 40px;
      left: 40px;
      max-width: 400px;
    }

    .apex-line--1 {
      width: 80px;
    }

    .apex-line--2 {
      width: 60px;
    }

    .apex-line--3 {
      width: 140px;
    }
  }

  @media screen and (max-width: 749px) {
    .forge-apex-hero {
      min-height: 500px;
    }

    .apex-ghost,
    .apex-fill {
      font-size: clamp(6rem, 16vw, 8rem);
      top: 5%;
      left: -8%;
    }

    .apex-hero__media {
      width: 100%;
      height: 50%;
      top: auto;
      bottom: 0;
      clip-path: polygon(0% 20%, 100% 0%, 100% 100%, 0% 100%);
    }

    .apex-hero__content {
      bottom: auto;
      top: 50%;
      left: 20px;
      right: 20px;
      max-width: none;
    }

    .apex-hero__heading {
      font-size: clamp(2.4rem, 8vw, 3rem);
    }

    .apex-line {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .apex-fill {
      animation: none;
      clip-path: inset(0 0% 0 0);
    }

    .apex-line {
      animation: none;
      opacity: 1;
    }
  }
</style>

{% schema %}
{
  "name": "Apex Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow Text",
      "default": "BUILT FOR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PERFORMANCE."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Performance →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (optional)",
      "info": "YouTube or Vimeo link for background video"
    }
  ],
  "presets": [
    {
      "name": "Apex Hero"
    }
  ]
}
{% endschema %}