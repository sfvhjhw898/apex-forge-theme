{% comment %}
  APEX Performance — Main Banner
  Full-viewport kinetic hero with diagonal brand name reveal
{% endcomment %}

<style>
  .apex-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    background: #0A0A0A;
    overflow: hidden;
  }

  .apex-brand-layer {
    position: absolute;
    top: -5%;
    left: -3%;
    z-index: 1;
    pointer-events: none;
    user-select: none;
  }

  .apex-ghost,
  .apex-fill {
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 900;
    font-size: clamp(12rem, 20vw, 22rem);
    line-height: 0.85;
    transform: rotate(-5deg);
    white-space: nowrap;
  }

  .apex-ghost {
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.08);
    color: transparent;
  }

  .apex-fill {
    position: absolute;
    top: 0;
    left: 0;
    color: white;
    z-index: 2;
    clip-path: inset(0 100% 0 0);
    animation: apex-reveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  @keyframes apex-reveal {
    to {
      clip-path: inset(0 0% 0 0);
    }
  }

  .apex-accent-lines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .apex-line-1,
  .apex-line-2,
  .apex-line-3 {
    position: absolute;
    background: #FF4500;
    height: 3px;
    transform: rotate(-5deg);
    opacity: 0;
    animation: apex-line-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .apex-line-1 {
    width: 120px;
    top: 30%;
    left: 2%;
    animation-delay: 0.3s;
  }

  .apex-line-2 {
    width: 80px;
    top: 45%;
    left: 5%;
    animation-delay: 0.5s;
  }

  .apex-line-3 {
    width: 200px;
    top: 60%;
    left: 0%;
    animation-delay: 0.7s;
  }

  @keyframes apex-line-in {
    to {
      opacity: 1;
    }
  }

  .apex-hero__media {
    position: absolute;
    right: 0;
    top: 0;
    width: 45%;
    height: 100%;
    z-index: 3;
    clip-path: polygon(8% 0%, 100% 0%, 100% 100%, 0% 100%);
  }

  .apex-hero__media img,
  .apex-hero__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.15) contrast(1.1);
  }

  .apex-hero__content {
    position: absolute;
    bottom: 60px;
    left: 60px;
    z-index: 5;
    max-width: 600px;
  }

  .apex-hero__eyebrow {
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 500;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
    margin: 0 0 0.6rem;
  }

  .apex-hero__heading {
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(3rem, 5vw, 5.5rem);
    letter-spacing: -0.01em;
    color: white;
    margin: 0.6rem 0 1.6rem;
    line-height: 1;
  }

  .apex-hero__cta {
    display: inline-block;
    padding: 14px 32px;
    background: #FF4500;
    color: white;
    font-family: Geist, -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 700;
    font-size: 16px;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .apex-hero__cta:hover {
    box-shadow: 0 0 30px rgba(255, 69, 0, 0.4);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .apex-hero {
      min-height: 500px;
    }

    .apex-ghost,
    .apex-fill {
      font-size: clamp(8rem, 18vw, 12rem);
    }

    .apex-hero__media {
      width: 55%;
      clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
    }

    .apex-hero__content {
      bottom: 40px;
      left: 40px;
      max-width: 400px;
    }

    .apex-hero__heading {
      font-size: clamp(2.2rem, 8vw, 3rem);
    }

    .apex-line-1 {
      width: 80px;
    }

    .apex-line-2 {
      width: 60px;
    }

    .apex-line-3 {
      width: 140px;
    }
  }

  @media (max-width: 480px) {
    .apex-hero__content {
      bottom: 30px;
      left: 20px;
      right: 20px;
    }

    .apex-hero__media {
      width: 65%;
      clip-path: polygon(20% 0%, 100% 0%, 100% 100%, 0% 100%);
    }

    .apex-ghost,
    .apex-fill {
      font-size: clamp(6rem, 16vw, 8rem);
      top: -3%;
      left: -5%;
    }
  }
</style>

<section class="apex-hero">
  <div class="apex-brand-layer">
    <div class="apex-ghost">APEX</div>
    <div class="apex-fill">APEX</div>
  </div>

  <div class="apex-accent-lines">
    <div class="apex-line-1"></div>
    <div class="apex-line-2"></div>
    <div class="apex-line-3"></div>
  </div>

  {% if section.settings.image != blank or section.settings.video_url != blank %}
    <div class="apex-hero__media" data-forge-parallax="0.3">
      {% if section.settings.video_url != blank %}
        <video
          autoplay
          muted
          loop
          playsinline
          loading="eager"
          fetchpriority="high"
        >
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      {% elsif section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1920
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '375, 750, 1100, 1500, 1920',
            sizes: '45vw',
            alt: section.settings.image.alt | escape
        }}
      {% endif %}
    </div>
  {% endif %}

  <div class="apex-hero__content">
    {% if section.settings.eyebrow != blank %}
      <div class="apex-hero__eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}

    <h1 class="apex-hero__heading" data-forge-split="chars" data-forge-split-anim="wave">
      {{ section.settings.heading | default: 'PERFORMANCE.' }}
    </h1>

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="apex-hero__cta"
        data-forge-magnet="0.5"
      >
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "MP4 video URL. Overrides image if provided."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "BUILT FOR"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PERFORMANCE."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Performance →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Main Banner"
    }
  ]
}
{% endschema %}